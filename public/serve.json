{
	"headers": [
		{
			"source": "**",
			"headers": [
				{ "key": "X-Frame-Options", "value": "SAMEORIGIN" },
				{ "key": "X-Content-Type-Options", "value": "nosniff" },
				{ "key": "X-XSS-Protection", "value": "1; mode=block" },
				{ "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
				{ "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
				{
					"key": "Strict-Transport-Security",
					"value": "max-age=31536000; includeSubDomains; preload"
				},
				{
					"key": "Content-Security-Policy",
					"value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://umami.fahari.pro; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://umami.fahari.pro; worker-src 'self'; manifest-src 'self'"
				}
			]
		},
		{
			"source": "assets/**",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
		},
		{
			"source": "sw.js",
			"headers": [{ "key": "Cache-Control", "value": "no-store" }]
		},
		{
			"source": "index.html",
			"headers": [{ "key": "Cache-Control", "value": "no-cache" }]
		}
	]
}
